# =============================================================================
# FalconAI — Storage stack environment
# Used by: make deploy-storage
# Copy to .env.storage, edit secrets, then deploy on any host.
# =============================================================================

COMPOSE_PROJECT_NAME=falcon-storage

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=falcon_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=pass998!
POSTGRES_PORT=12002

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=pass998!
MINIO_API_PORT=12004
MINIO_CONSOLE_PORT=12015

# LAN IP other hosts use to reach Postgres/MinIO on this machine.
# Auto-detected via default route; set explicitly if detection is wrong.
# STORAGE_ADVERTISE_IP=192.168.1.10

# Optional — set when using MinIO console via app gateway (/storage-console/)
# MINIO_BROWSER_REDIRECT_URL=http://APP_HOST:12006/storage-console

# -----------------------------------------------------------------------------
# Docker build
# -----------------------------------------------------------------------------
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
