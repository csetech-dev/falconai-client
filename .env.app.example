# =============================================================================
# FalconAI — Application stack environment
# Used by: make deploy-app
# Copy to .env.app, set storage host/IP, then deploy on any host.
# =============================================================================

COMPOSE_PROJECT_NAME=falcon-app

# -----------------------------------------------------------------------------
# Storage host (IP/hostname where Postgres + MinIO are reachable)
# -----------------------------------------------------------------------------
STORAGE_SERVER_IP=10.0.0.5

# Must match the host running deploy-storage (deploy script sets these if omitted)
POSTGRES_HOST=10.0.0.5
POSTGRES_PORT=12002
POSTGRES_USER=postgres
POSTGRES_PASSWORD=pass998!

MINIO_ENDPOINT=10.0.0.5:12004
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=pass998!
MINIO_PUBLIC_ENDPOINT=10.0.0.5:12004
MINIO_CONSOLE_ENDPOINT=10.0.0.5:12015
# MINIO_ACCESS_KEY must match MINIO_ROOT_USER in .env.storage
# MINIO_SECRET_KEY must match MINIO_ROOT_PASSWORD in .env.storage

# -----------------------------------------------------------------------------
# Public URLs (this host's IP or domain — webhooks and browser-facing links)
# -----------------------------------------------------------------------------
PUBLIC_GATEWAY_URL=http://10.0.0.6:12006

# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
# Optional — leave empty if unused
VIDEO_AI_API_URL=
YT_API_KEY=AIzaSyA7xr-nP61TWmSrylLziRD7oWXPHqis65Q
WORKER_API_PASSWORD=85234569495721

# OpenSearch indexing (off by default — enable when core is up and you want auto-populate)
SEARCH_STARTUP_SEED=false
SEARCH_SYNC_ON_START=false
SOCIAL_SCRAPER_CONCURRENCY=10

# Telegram worker (optional — only if using worker-telegram scraper)
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_PHONE=
# TELEGRAM_PASSWORD=

# -----------------------------------------------------------------------------
# GHCR client deploy (image-only — no source build on this host)
# Leave GHCR_IMAGE_PREFIX empty to build from local source instead.
# -----------------------------------------------------------------------------
# GHCR_IMAGE_PREFIX=ghcr.io/your-github-org/falconai
# FALCON_IMAGE_TAG=latest
# FALCON_DEPLOY_MODE=ghcr

# -----------------------------------------------------------------------------
# Docker build
# -----------------------------------------------------------------------------
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Prune stopped containers (+ dangling images after app build). Set 0 to disable.
PRUNE_AFTER_BUILD=1
